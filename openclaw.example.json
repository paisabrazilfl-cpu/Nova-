            "onlyMainContent": true,
            "maxAgeMs": 172800000,
            "timeoutSeconds": 60
          }
        }
      }
    }
  },

  "mcp": {
    "servers": {}
  },

  "memory": {
    "backend": "qmd"
  },

  "cron": {
    "enabled": true
  },

  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "${HOOKS_TOKEN}"
  }
}
