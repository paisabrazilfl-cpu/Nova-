  "agents": {
    "defaults": {
      "model": {
        "primary": "bitdeer/Qwen/Qwen3-235B-A22B",
        "fallbacks": [
          "bitdeer/openai/gpt-oss-20b"
        ]
      },
      "params": {
        "temperature": 0.1,
        "topP": 1.0
      },
      "bootstrapMaxChars": 200000,
      "bootstrapTotalMaxChars": 800000,
      "models": {
        "gemini/gemini-2.5-pro": { "alias": "Main (Gemini 2.5 Pro)" },
        "gemini/gemini-2.5-flash": { "alias": "Fallback 0 (Gemini 2.5 Flash)" },
        "bitdeer/MiniMaxAI/MiniMax-M2.5": { "alias": "Fallback 1 (MiniMax M2.5 — fast)" },
        "bitdeer/moonshotai/Kimi-K2.6": { "alias": "Fallback 2 (Kimi K2.6)" },
        "bitdeer/nvidia/NVIDIA-Nemotron-3-Super-120B-A12B": { "alias": "Fallback 3 (Nemotron 3 Super)" },
        "bitdeer/deepseek-ai/DeepSeek-V3.2": { "alias": "Fallback 4 (DeepSeek V3.2)" },
        "bitdeer/google/gemma-4-31B-it": { "alias": "Cheap fallback (Gemma 4 31B)" },
        "bitdeer/google/gemma-4-E4B-it": { "alias": "Classifier / audio (Gemma 4 small)" },
        "bitdeer/mistralai/Ministral-3-3B-Instruct-2512": { "alias": "Classifier alt (Ministral 3B)" },
        "bitdeer/mistralai/Devstral-2-123B-Instruct-2512": { "alias": "Coding (Devstral 2)" },
        "bitdeer/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning": { "alias": "Vision/Reasoning (Nemotron Nano)" },
        "bitdeer/Qwen/Qwen3-VL-235B-A22B-Instruct": { "alias": "Vision fallback (Qwen3-VL 235B)" }
      },
      "memorySearch": {
        "provider": "openai",
        "model": "BAAI/bge-m3",
        "query": {
          "maxResults": 8,
          "hybrid": {
            "enabled": true,
            "candidateMultiplier": 4,
            "mmr": { "enabled": true, "lambda": 0.7 }
          }
        }
      },
      "imageGenerationModel": {
        "primary": "litellm/google/imagen-4.0-ultra",
        "fallbacks": ["litellm/black-forest-labs/FLUX-2-pro", "litellm/seedream-5.0-lite"]
      }
    }
  },

